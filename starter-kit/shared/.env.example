# ~/.claude/.env — Credential vault
# Copy this to ~/.claude/.env and fill in your values.
# NEVER commit this file to git. Add to .gitignore.
#
# This file is sourced by session-start.sh with set -a (auto-export).
# All variables become available to child processes (hooks, scripts, etc.).

# ── Anthropic (Claude API) ─────────────────────────────────────
# Only needed if hooks or scripts call the Claude API directly.
# Your Claude Code subscription handles the CLI itself.
# ANTHROPIC_API_KEY='sk-ant-...'

# ── Gemini (for pre-compact summarization) ─────────────────────
# The pre-compact hook uses Gemini to summarize transcripts before
# context compaction. Without this, it falls back to jq extraction.
# GEMINI_API_KEY='AIza...'

# ── GitHub ─────────────────────────────────────────────────────
# Used by hooks for git operations. Usually not needed if gh CLI
# is already authenticated.
# GITHUB_PERSONAL_ACCESS_TOKEN='ghp_...'

# ── Supabase (if using Supabase integration) ───────────────────
# Required by the artifact guard's remote_strict path.
# SUPABASE_ACCESS_TOKEN='sbp_...'
# SUPABASE_DB_PASSWORD='...'
# SUPABASE_DB_URL='postgresql://...'

# ── ClickUp (optional — task tracking integration) ─────────────
# Only used when ENABLE_CLICKUP=1 is set.
# CLICKUP_API_TOKEN='pk_...'

# ── n8n (optional — workflow automation) ───────────────────────
# N8N_CLOUD_API_KEY='eyJ...'
# N8N_LOCAL_API_KEY='eyJ...'

# ── Custom ─────────────────────────────────────────────────────
# Add your own API keys below:
